{
  "name": "asb-ts",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b -w",
    "biome": "biome check .",
    "biome:fix": "biome check --write --unsafe .",
    "tools:getValues": "bun run ./tools/getValues.ts && bun run biome:fix",
    "license:gen": "bun x license-checker-rseidelsohn > ./THIRD_PARTY_LICENSES.txt"
  },
  "dependencies": {
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "typescript": "catalog:",
    "license-checker-rseidelsohn": "catalog:"
  }
}
